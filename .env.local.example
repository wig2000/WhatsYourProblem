# ─── LLM ──────────────────────────────────────────────────────────────────────
# Call 1 (complaint parse + PII strip): Claude claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Call 2 (5 meme briefs + captions): Grok 3 via xAI API
# Set to grok-3-mini to test cost/quality tradeoff
XAI_API_KEY=
GROK_MODEL=grok-3

# ─── Image generation ──────────────────────────────────────────────────────────
# OpenAI — gpt-image-2 (surreal/absurdist brief). Token-based billing.
OPENAI_API_KEY=

# Google AI Studio — Imagen 4 Ultra (realistic brief). ~$0.06/image flat rate.
GOOGLE_AI_API_KEY=

# fal.ai — Flux 2 Pro (illustration/cartoon brief). Flat per-image.
FAL_API_KEY=

# ─── Database (Neon serverless Postgres) ──────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
# Use the "pooled" connection string for serverless
DATABASE_URL=

# ─── Storage (Vercel Blob) ────────────────────────────────────────────────────
# Get from: Vercel dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=

# ─── Cron security ────────────────────────────────────────────────────────────
# Random secret verified in cron route headers. Generate: openssl rand -hex 32
CRON_SECRET=

# ─── B2B dashboard (Phase 5) ──────────────────────────────────────────────────
# Simple MVP gate: comma-separated email addresses allowed to access /dashboard
# Replace with Clerk auth when going to production B2B
DASHBOARD_ALLOWED_EMAILS=
DASHBOARD_PASSWORD=
